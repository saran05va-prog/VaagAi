# RAG Service Environment Variables
# Copy to .env and fill in your values

# Groq API Key (get free tier at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Embedding Model (default: all-MiniLM-L6-v2)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# LLM Model (Groq supported models: llama-3-70b-versatile, llama-3-8b-8192, mixtral-8x7b-32768)
LLM_MODEL=llama-3-70b-versatile

# Chroma persistence directory
CHROMA_PERSIST_DIRECTORY=./data/chroma_db

# Source documents directory
DOCUMENTS_DIRECTORY=./data/documents

# Chunk size for document splitting
CHUNK_SIZE=500

# Chunk overlap
CHUNK_OVERLAP=50

# Number of chunks to retrieve
TOP_K=5