// ============================================
// SMART AI FARMING PLATFORM - PRISMA SCHEMA
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  OWNER
  MANAGER
  WORKER
  VIEWER
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskType {
  WATERING
  FERTILIZER
  PESTICIDE
  WEEDING
  PRUNING
  HARVESTING
  OTHER
}

enum NotificationType {
  TASK_DUE
  TASK_COMPLETED
  TASK_MISSED
  WEATHER_ALERT
  MARKET_ALERT
  AI_INSIGHT
  SYSTEM
}

enum FileType {
  PDF
  IMAGE
  DOCUMENT
  REPORT
  INVOICE
  AI_REPORT
}

enum CropPhase {
  PREPARATION
  SOWING
  GERMINATION
  VEGETATIVE
  FLOWERING
  FRUITING
  MATURATION
  HARVESTING
}

// ============================================
// MODELS
// ============================================

// User Account - Multi-tenant support
model User {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String    @map("password_hash")
  firstName         String?   @map("first_name")
  lastName          String?   @map("last_name")
  phone             String?
  avatarUrl         String?   @map("avatar_url")
  role              UserRole  @default(VIEWER)
  isActive          Boolean   @default(true) @map("is_active")
  emailVerified     Boolean   @default(false) @map("email_verified")
  farmName          String?   @map("farm_name")
  farmLocation      String?   @map("farm_location")
  farmArea          Float?    @map("farm_area")
  lastLoginAt       DateTime? @map("last_login_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Relations
  farms             FarmUser[]
  notifications     Notification[]
  aiInsights        AIInsight[]
  uploadFiles       UploadedFile[]
  sessions          UserSession[]

  // Indexes
  @@index([email])
  @@index([role])
  @@map("users")
}

// User Session for JWT refresh tokens
model UserSession {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  token         String   @unique
  refreshToken  String?  @unique @map("refresh_token")
  expiresAt     DateTime @map("expires_at")
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  isRevoked     Boolean  @default(false) @map("is_revoked")
  createdAt     DateTime @default(now()) @map("created_at")

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([refreshToken])
  @@map("user_sessions")
}

// Farm - Multi-tenant farm management
model Farm {
  id            String    @id @default(cuid())
  name          String
  location      String?
  latitude      Float?
  longitude     Float?
  soilType      String?   @map("soil_type")
  acreage       Float?
  timezone      String    @default("Asia/Kolkata")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  users         FarmUser[]
  cropPlans     CropPlan[]
  tasks         Task[]
  weatherHistory WeatherHistory[]
  marketHistory  MarketPriceHistory[]
  yieldRecords   YieldRecord[]
  uploads       UploadedFile[]

  // Indexes
  @@index([name])
  @@index([location])
  @@map("farms")
}

// Farm User - Many-to-many relationship with roles
model FarmUser {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  farmId    String    @map("farm_id")
  role      UserRole  @default(VIEWER)
  isActive  Boolean   @default(true) @map("is_active")
  joinedAt  DateTime  @default(now()) @map("joined_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  farm      Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@unique([userId, farmId])
  @@index([userId])
  @@index([farmId])
  @@map("farm_users")
}

// Crop Plan - Agricultural planning
model CropPlan {
  id              String      @id @default(cuid())
  farmId          String      @map("farm_id")
  cropName        String      @map("crop_name")
  variety         String?
  areaHa          Float?      @map("area_ha")
  expectedYield   Float?      @map("expected_yield")
  yieldUnit       String?     @map("yield_unit")
  startDate       DateTime    @map("start_date")
  endDate         DateTime    @map("end_date")
  currentPhase    CropPhase   @default(PREPARATION) @map("current_phase")
  notes           String?
  isActive        Boolean     @default(true) @map("is_active")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  // Relations
  farm            Farm        @relation(fields: [farmId], references: [id], onDelete: Cascade)
  tasks           Task[]
  aiInsights      AIInsight[]

  // Indexes
  @@index([farmId])
  @@index([cropName])
  @@index([startDate])
  @@index([endDate])
  @@index([currentPhase])
  @@map("crop_plans")
}

// Task - Maintenance task scheduling
model Task {
  id            String        @id @default(cuid())
  planId        String?       @map("plan_id")
  farmId        String        @map("farm_id")
  taskType      TaskType      @map("task_type")
  title         String
  description   String?
  scheduledDate DateTime      @map("scheduled_date")
  completedDate DateTime?     @map("completed_date")
  dueDate       DateTime?     @map("due_date")
  status        TaskStatus    @default(PENDING)
  priority      TaskPriority  @default(MEDIUM)
  quantity      Float?
  unit          String?
  notes         String?
  isAutoGenerated Boolean    @default(false) @map("is_auto_generated")
  yieldImpact   Float?        @map("yield_impact")
  recoveryAction String?     @map("recovery_action")
  completedAt   DateTime?     @map("completed_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  // Relations
  plan          CropPlan?     @relation(fields: [planId], references: [id], onDelete: SetNull)
  farm          Farm          @relation(fields: [farmId], references: [id], onDelete: Cascade)
  notifications  Notification[]

  // Indexes
  @@index([farmId])
  @@index([planId])
  @@index([scheduledDate])
  @@index([status])
  @@index([taskType])
  @@index([dueDate])
  @@map("tasks")
}

// Uploaded File - Supabase Storage metadata
model UploadedFile {
  id            String      @id @default(cuid())
  userId        String      @map("user_id")
  farmId        String?     @map("farm_id")
  fileName      String      @map("file_name")
  fileType      FileType    @map("file_type")
  fileSize      Int         @map("file_size")
  mimeType      String?     @map("mime_type")
  storageKey    String      @unique @map("storage_key")
  bucketName    String      @map("bucket_name")
  publicUrl     String?     @map("public_url")
  isPublic      Boolean     @default(false) @map("is_public")
  checksum      String?
  metadata      Json?
  description   String?
  tags          String[]
  uploadedAt    DateTime    @default(now()) @map("uploaded_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  farm          Farm?       @relation(fields: [farmId], references: [id], onDelete: SetNull)

  // Indexes
  @@index([userId])
  @@index([farmId])
  @@index([fileType])
  @@index([uploadedAt])
  @@map("uploaded_files")
}

// Weather History - Weather data persistence
model WeatherHistory {
  id              String   @id @default(cuid())
  farmId          String   @map("farm_id")
  location        String
  latitude        Float
  longitude       Float
  temperature     Float
  humidity        Int
  windSpeed       Float
  weatherCode     Int      @map("weather_code")
  weatherDesc     String   @map("weather_description")
  precipitation   Float
  recordedAt      DateTime @map("recorded_at")
  createdAt       DateTime @default(now()) @map("created_at")

  farm            Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([farmId])
  @@index([location])
  @@index([recordedAt])
  @@unique([farmId, location, recordedAt])
  @@map("weather_history")
}

// Market Price History - Agricultural market prices
model MarketPriceHistory {
  id              String   @id @default(cuid())
  farmId          String?  @map("farm_id")
  cropName        String   @map("crop_name")
  marketType      String   @map("market_type")
  market          String
  pricePerKg      Float    @map("price_per_kg")
  currency        String   @default("INR")
  trend           String?
  unit            String   @default("₹/kg")
  recordedAt      DateTime @map("recorded_at")
  createdAt       DateTime @default(now()) @map("created_at")

  farm            Farm?    @relation(fields: [farmId], references: [id], onDelete: SetNull)

  // Indexes
  @@index([farmId])
  @@index([cropName])
  @@index([marketType])
  @@index([market])
  @@index([recordedAt])
  @@map("market_price_history")
}

// Yield Record - Harvest tracking
model YieldRecord {
  id            String    @id @default(cuid())
  farmId        String    @map("farm_id")
  cropName      String    @map("crop_name")
  quantity      Float
  unit          String
  revenue       Float?
  harvestDate   DateTime  @map("harvest_date")
  quality       String?
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  farm          Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([farmId])
  @@index([cropName])
  @@index([harvestDate])
  @@map("yield_records")
}

// AI Insight - AI-generated recommendations
model AIInsight {
  id            String        @id @default(cuid())
  userId        String        @map("user_id")
  farmId        String?       @map("farm_id")
  planId        String?       @map("plan_id")
  taskId        String?       @map("task_id")
  insightType   String        @map("insight_type")
  title         String
  description   String
  severity      TaskPriority  @default(MEDIUM)
  confidence    Float?
  metadata      Json?
  isRead        Boolean       @default(false) @map("is_read")
  isActioned    Boolean       @default(false) @map("is_actioned")
  createdAt     DateTime      @default(now()) @map("created_at")

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  farm          Farm?         @relation(fields: [farmId], references: [id], onDelete: SetNull)
  plan          CropPlan?     @relation(fields: [planId], references: [id], onDelete: SetNull)
  task          Task?         @relation(fields: [taskId], references: [id], onDelete: SetNull)

  // Indexes
  @@index([userId])
  @@index([farmId])
  @@index([planId])
  @@index([taskId])
  @@index([isRead])
  @@index([isActioned])
  @@index([createdAt])
  @@map("ai_insights")
}

// Notification System
model Notification {
  id            String            @id @default(cuid())
  userId        String            @map("user_id")
  taskId        String?           @map("task_id")
  type          NotificationType  @default(SYSTEM)
  title         String
  message       String
  data          Json?
  isRead        Boolean           @default(false) @map("is_read")
  isArchived    Boolean           @default(false) @map("is_archived")
  sentAt        DateTime          @default(now()) @map("sent_at")
  readAt        DateTime?         @map("read_at")

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  task          Task?             @relation(fields: [taskId], references: [id], onDelete: SetNull)

  // Indexes
  @@index([userId])
  @@index([type])
  @@index([isRead])
  @@index([sentAt])
  @@map("notifications")
}

// Autosave Draft - For draft autosave functionality
model AutosaveDraft {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  data        Json
  isPartial   Boolean  @default(true) @map("is_partial")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Indexes
  @@unique([userId, entityType, entityId])
  @@index([userId])
  @@index([entityType])
  @@map("autosave_drafts")
}