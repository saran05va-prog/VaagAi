# ========================================
# SMART AI FARMING PLATFORM
# Environment Configuration
# ========================================
GROQ_API_KEY=
# ========================================
# DATABASE (PostgreSQL via Supabase)
# ========================================
DATABASE_URL=
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=
POSTGRES_PORT=

# ========================================
# AUTHENTICATION
# ========================================
JWT_SECRET=your-super-secret-key-change-in-production-min-32-chars-long
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# ========================================
# SUPABASE
# ========================================
SUPABASE_URL=
SUPABASE_SERVICE_KEY=your-supabase-service-key
SUPABASE_ANON_KEY=your-supabase-anon-key

# ========================================
# REDIS CACHE
# ========================================
# Use IPv4 loopback to avoid IPv6 (::1) resolution causing duplicate connection attempts
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ========================================
# WEATHER API (Open-Meteo - Free, no key needed)
# ========================================
WEATHER_API_KEY=

# ========================================
# AGMARKNET MARKET DATA API
# ========================================
# Get API key from https://api.data.gov.in
AGMARKNET_API_KEY=

# ========================================
# SERVER CONFIGURATION
# ========================================
PORT=3002
NODE_ENV=development

# ========================================
# SECURITY
# ========================================
# Comma-separated allowed origins for CORS (production)
ALLOWED_ORIGINS=

# ========================================
# FILE UPLOADS
# ========================================
MAX_FILE_SIZE=10485760
UPLOAD_BUCKET_NAME=farm-documents

# ========================================
# RATE LIMITING
# ========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ========================================
# LOGGING
# ========================================
LOG_LEVEL=info

# ========================================
# PRODUCTION DEPLOYMENT
# ========================================
# Set these in production
# POSTGRES_PASSWORD=<strong-password>
# REDIS_PASSWORD=<strong-password>
# JWT_SECRET=<strong-random-secret>

# ========================================
# GOOGLE OAUTH
# ========================================
# Get from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GOOGLE_REDIRECT_URI=

# ========================================
# EMAIL (Resend) - For OTP verification
# ========================================
# Get API key from https://resend.com
RESEND_API_KEY=re_123456789
