# VaagAi Environment Configuration
# For production, update these URLs to your deployed backend
VITE_API_URL=https://your-backend-app.railway.app
VITE_SOCKET_URL=https://your-backend-app.railway.app
VITE_APP_NAME=VaagAi

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# Project ref = the subdomain of VITE_SUPABASE_URL (e.g. "abcdefghij" from
# https://abcdefghij.supabase.co). Used by lib/api.ts to read the auth token
# from Supabase's localStorage key (sb-<ref>-auth-token) on cold reloads,
# before onAuthStateChange has fired INITIAL_SESSION. If you rename or move
# the Supabase project, update this too.
VITE_SUPABASE_PROJECT_REF=abcdefghij

# API Keys (copy from backend .env)
VITE_GROQ_API_KEY=your-groq-api-key
VITE_WEATHER_API_KEY=your-weather-api-key
VITE_AGMARKNET_API_KEY=your-agmarknet-api-key